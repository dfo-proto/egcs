<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DFO Funding Portal — Application form (mobile)</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Noto+Sans:wght@400;700&display=swap" rel="stylesheet">
<style>
  /* ---------- GC Design System tokens (unchanged from desktop) ---------- */
  :root{
    --gc-text:#333333;
    --gc-link:#284162;
    --gc-link-hover:#0535d2;
    --gc-red:#af3c43;          /* page title underline */
    --gc-flag-red:#f4252b;
    --gc-navy:#26374a;         /* dark buttons / nav / active step */
    --gc-badge:#2962A3;        /* CAD amount badge */
    --gc-green:#278400;        /* completed step */
    --gc-danger:#b10e1e;       /* delete */
    --gc-border:#cccccc;
    --gc-rule:#bbbbbb;
    --gc-bg-muted:#f5f6f7;
    --gc-pill:#e1eaf0;         /* "In progress" pill */
    --gc-info:#269abc;         /* info notice rule */
    --gc-focus:#ffbf47;        /* GC focus highlight */
    --body:"Noto Sans",-apple-system,"Segoe UI",Roboto,sans-serif;
    --display:"Lato",-apple-system,"Segoe UI",Roboto,sans-serif;
  }

  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:#e9ebee;
    font-family:var(--body);
    color:var(--gc-text);
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
    padding:24px 12px;
  }

  /* ---------- Phone frame (fixed viewport, app scrolls inside) ---------- */
  .device{
    width:320px;
    max-width:100%;
    height:680px;
    margin:0 auto;
    background:#fff;
    border-radius:28px;
    box-shadow:0 14px 40px rgba(0,0,0,.22);
    overflow:hidden;
    border:1px solid #d8dadd;
    position:relative;
    display:flex;
    flex-direction:column;
  }
  .device-notch{
    height:26px;background:#000;border-radius:0 0 16px 16px;width:140px;margin:0 auto;flex:0 0 auto;
  }

  .app{ /* the real, fluid mobile page — this is the scroll container */
    width:100%;
    flex:1 1 auto;
    overflow-y:auto;
    -webkit-overflow-scrolling:touch;
    background:#fff;
    position:relative;
  }

  /* ---------- Header / wordmark ---------- */
  header{padding:16px 16px 14px;border-bottom:1px solid #e2e4e6;}
  .wordmark-row{display:flex;align-items:center;justify-content:space-between;gap:12px;}
  .wordmark{display:flex;align-items:center;gap:10px;}
  .flag{flex:0 0 auto;width:40px;height:20px;display:block;}
  .wordmark .gov{font-family:var(--display);font-weight:700;font-size:14px;line-height:1.15;color:#000;}
  .wordmark .gov span{display:block;font-weight:400;}
  .lang{
    flex:0 0 auto;color:var(--gc-link);font-size:20px;font-weight:700;
    text-decoration:underline;text-underline-offset:3px;
  }

  /* search */
  .search{display:flex;margin-top:16px;}
  .search input{
    flex:1;min-width:0;height:52px;border:1px solid var(--gc-border);border-right:0;
    padding:0 14px;font-size:17px;font-family:var(--body);border-radius:0;color:#5a5a5a;
  }
  .search button{
    width:56px;height:52px;background:var(--gc-navy);border:0;color:#fff;cursor:pointer;
    display:flex;align-items:center;justify-content:center;flex:0 0 auto;
  }

  /* full-width Menu button */
  .menubar{padding:16px;}
  .menu-btn{
    width:100%;height:56px;border:1px solid var(--gc-navy);border-radius:6px;background:#fff;
    color:var(--gc-navy);font-family:var(--display);font-weight:700;font-size:20px;cursor:pointer;
  }
  .menu-btn[aria-expanded="true"]{background:var(--gc-navy);color:#fff;}

  /* slide-down main nav */
  .mainnav{display:none;border-top:1px solid #e4e6e8;border-bottom:1px solid #e4e6e8;background:var(--gc-bg-muted);}
  .mainnav.open{display:block;}
  .mainnav a{
    display:block;padding:14px 16px;color:var(--gc-link);text-decoration:none;font-size:16px;
    border-bottom:1px solid #e4e6e8;min-height:48px;
  }
  .mainnav a:last-child{border-bottom:0;}
  .mainnav a.nav-signout{font-weight:700;color:var(--gc-navy);}

  /* ---------- Content wrapper ---------- */
  main{padding:16px 16px 92px;}
  .breadcrumb{font-size:13px;color:var(--gc-text);margin-bottom:14px;display:flex;flex-wrap:wrap;gap:4px 6px;}
  .breadcrumb a{color:var(--gc-link);text-decoration:underline;}
  .breadcrumb .sep{color:#888;}

  h1{
    font-family:var(--display);font-size:32px;line-height:1.15;margin:4px 0 4px;color:#1c1c1c;font-weight:700;
  }
  h1::after{content:"";display:block;width:54px;height:3px;background:var(--gc-red);margin-top:8px;}
  .intro{margin:14px 0 0;font-size:16px;}
  .intro strong{font-weight:700;}
  .autosave{
    display:flex;align-items:center;gap:8px;margin:12px 0 0;
    font-size:14px;color:#5a5a5a;
  }
  .autosave svg{flex:0 0 auto;}

  /* ---------- "Application form menu" — in flow, sticky on scroll ---------- */
  .menu-sticky{
    position:sticky;top:0;z-index:60;margin:20px 0;
    background:#fff;padding:8px 0;
  }
  .menu-trigger{
    width:100%;display:flex;align-items:center;justify-content:center;gap:12px;
    background:#fff;border:2px solid var(--gc-navy);border-radius:8px;padding:10px 16px;
    cursor:pointer;min-height:45px;
    font-family:var(--display);font-weight:700;font-size:18px;color:var(--gc-navy);
  }
  .menu-trigger svg{width:20px;height:20px;flex:0 0 auto;}

  /* ---------- Bottom sheet ---------- */
  .sheet-overlay{
    position:absolute;inset:0;z-index:100;display:flex;align-items:flex-end;
    background:rgba(0,0,0,.45);
  }
  .sheet-overlay[hidden]{display:none;}
  .sheet{
    width:100%;max-height:90%;background:#fff;border-radius:16px 16px 0 0;
    display:flex;flex-direction:column;box-shadow:0 -8px 30px rgba(0,0,0,.25);
    animation:sheetUp .25s ease;
  }
  @keyframes sheetUp{from{transform:translateY(100%);}to{transform:translateY(0);}}
  .sheet-grab{width:40px;height:4px;border-radius:2px;background:#cfd3d7;margin:10px auto 2px;flex:0 0 auto;}
  .sheet-inner{overflow-y:auto;padding:6px 16px 24px;}
  .btn-close{
    width:100%;height:48px;background:#fff;border:1px solid var(--gc-navy);color:var(--gc-navy);
    border-radius:4px;font-weight:700;font-size:16px;cursor:pointer;font-family:var(--body);margin:6px 0 16px;
  }
  .sheet-title{font-family:var(--display);font-size:22px;font-weight:700;margin:0 0 4px;color:#1c1c1c;}

  /* steps inside the sheet (accordion) */
  .m-step{border-bottom:1px solid #eaecee;}
  .m-step:last-child{border-bottom:0;}
  .m-step-head{
    width:100%;display:flex;align-items:flex-start;gap:12px;background:none;border:0;cursor:pointer;
    padding:14px 4px;text-align:left;font-family:var(--body);min-height:56px;
  }
  .m-step-head .marker{
    flex:0 0 auto;width:28px;height:28px;border-radius:50%;border:2px solid #6f6f6f;color:#444;
    display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;background:#fff;
  }
  .m-step.done  .m-step-head .marker{background:var(--gc-green);border-color:var(--gc-green);color:#fff;}
  .m-step.active .m-step-head .marker{background:var(--gc-navy);border-color:var(--gc-navy);color:#fff;}
  .m-step-head .label{flex:1;font-weight:700;font-size:17px;color:var(--gc-text);margin-top:2px;}
  .m-step-head .chev{flex:0 0 auto;color:#555;margin-top:4px;transition:transform .2s;}
  .m-step.expanded .m-step-head .chev{transform:rotate(180deg);}

  .m-substeps{display:none;margin:0 0 8px 13px;padding:2px 0 2px 22px;border-left:2px solid var(--gc-border);}
  .m-step.expanded .m-substeps{display:block;}
  .m-substep{padding:10px 0;font-size:16px;color:var(--gc-text);}
  .m-substep .dot{margin-right:6px;}
  .m-substep.current{
    font-weight:700;background:var(--gc-bg-muted);
    margin:0 -16px 0 -24px;padding:10px 16px 10px 24px;border-radius:0;
  }
  .pill{
    display:inline-flex;align-items:center;gap:6px;background:var(--gc-pill);color:var(--gc-navy);
    font-size:13px;font-weight:700;border-radius:14px;padding:5px 12px;margin-top:8px;
  }
  .pill svg{width:13px;height:13px;}
  .pill.complete{background:var(--gc-green);color:#fff;padding-right:6px;}
  .pill.complete .check{
    width:17px;height:17px;border-radius:50%;background:#fff;
    display:inline-flex;align-items:center;justify-content:center;
  }
  .pill.complete .check svg{width:11px;height:11px;stroke:var(--gc-green);}

  /* ---------- Form sections ---------- */
  h2{font-family:var(--display);font-size:26px;font-weight:700;margin:28px 0 14px;color:#1c1c1c;}
  .field-label{font-weight:700;font-size:16px;}
  .field-label .req{font-weight:400;color:#555;}
  .field-help{font-size:14px;color:#5a5a5a;margin:2px 0 8px;}
  .field{margin-bottom:18px;}

  /* error message (shown above the input when the field is in error) */
  .field-error{
    display:none;align-items:center;gap:7px;margin:0 0 8px;
    color:var(--gc-danger);font-weight:700;font-size:15px;
  }
  .field.error .field-error{display:flex;}
  .field-error svg{width:18px;height:18px;flex:0 0 auto;}

  input[type=text],input[type=number],select,textarea{
    width:100%;font-family:var(--body);font-size:16px;color:var(--gc-text);
    border:2px solid #333;border-radius:4px;padding:0 12px;background:#fff;
  }
  input[type=text],input[type=number],select{height:48px;}
  textarea{min-height:120px;padding:12px;line-height:1.5;resize:vertical;}
  select{appearance:none;background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%23333' stroke-width='3'><path d='M6 9l6 6 6-6'/></svg>");background-repeat:no-repeat;background-position:right 14px center;padding-right:40px;}

  /* focus */
  input:focus,select:focus,textarea:focus{
    border-color:#2962A3;outline:3px solid rgba(41,98,163,.30);outline-offset:0;
  }
  /* error */
  .field.error input,.field.error select,.field.error textarea{border-color:var(--gc-danger);}
  /* error while focused — focus colour wins, message stays */
  .field.error input:focus,.field.error select:focus,.field.error textarea:focus{border-color:#2962A3;}
  /* disabled */
  input:disabled,select:disabled,textarea:disabled{
    background:#d6d6d6;border-color:#9a9a9a;color:#6f6f6f;cursor:not-allowed;
  }

  /* ---------- Activity card ---------- */
  .activity{border:1px solid var(--gc-border);border-radius:6px;margin:18px 0;overflow:hidden;}
  .badge-row{padding:0;}
  .badge{
    display:inline-block;background:var(--gc-badge);color:#fff;font-weight:700;font-size:14px;
    padding:5px 12px;border-radius:0 0 4px 0;
  }
  .activity-head{
    display:flex;align-items:flex-start;gap:10px;padding:6px 16px 0;cursor:pointer;
  }
  .activity-head .acc-chev{flex:0 0 auto;margin-top:4px;transition:transform .2s;}
  .activity.collapsed .acc-chev{transform:rotate(-90deg);}
  .activity-title{font-family:var(--display);font-size:20px;font-weight:700;margin:0;color:#1c1c1c;}
  .activity-dates{font-size:15px;color:var(--gc-text);margin:2px 16px 0;}
  .activity-body{padding:14px 16px 16px;}
  .activity.collapsed .activity-body{display:none;}

  .btn-add{
    display:inline-flex;align-items:center;gap:8px;background:#fff;border:1px solid var(--gc-navy);
    color:var(--gc-navy);font-weight:700;font-size:15px;border-radius:4px;padding:0 16px;height:48px;
    cursor:pointer;font-family:var(--body);
  }
  .btn-add svg{width:18px;height:18px;}

  /* ---------- Cost-category form (rendered inside the bottom sheet) ---------- */
  .cc-form{margin-bottom:0;}
  .cc-form h4{font-family:var(--display);font-size:20px;font-weight:700;margin:0 0 16px;}
  .cc-form .field{margin-bottom:18px;}
  .form-actions{display:flex;flex-direction:column;gap:12px;margin-top:8px;}
  .btn-done{background:var(--gc-navy);color:#fff;border:0;border-radius:4px;width:100%;height:48px;padding:0 22px;font-size:16px;font-weight:700;cursor:pointer;}
  .btn-delete{background:var(--gc-danger);color:#fff;border:0;border-radius:4px;width:100%;height:48px;padding:0 22px;font-size:16px;font-weight:700;cursor:pointer;}

  /* ---------- Saved cost-category summary: one card per category ---------- */
  .cc-card{border:1px solid var(--gc-border);border-radius:6px;margin-bottom:14px;overflow:hidden;}
  .cc-card-head{background:var(--gc-bg-muted);border-bottom:1px solid var(--gc-border);padding:14px 16px;}
  .cc-card-head .cc-name{font-family:var(--display);font-weight:700;font-size:20px;line-height:1.2;margin:0;color:#1c1c1c;}
  .cc-card-body{padding:0 16px;}
  .cc-row{padding:14px 0;border-bottom:1px solid var(--gc-rule);}
  .cc-row .k{font-weight:700;font-size:16px;margin:0 0 3px;}
  .cc-row .v{font-size:16px;margin:0;}
  .cc-card-actions{display:flex;gap:22px;padding:6px 16px 12px;}
  .link-edit,.link-delete{
    display:inline-flex;align-items:center;gap:7px;background:none;border:0;cursor:pointer;
    font-size:16px;padding:8px 0;min-height:44px;font-family:var(--body);
  }
  .link-edit{color:var(--gc-link);text-decoration:underline;text-underline-offset:2px;}
  .link-delete{color:var(--gc-danger);}
  .link-edit svg{width:16px;height:16px;}
  .link-delete svg{width:16px;height:16px;}

  /* activity-level totals: labels with blue badges */
  .activity-totals{margin:4px 0 14px;}
  .at-divider{border:0;border-top:1px solid var(--gc-rule);margin:14px 0;}
  .at-row{margin-bottom:14px;}
  .at-label{font-weight:700;font-size:16px;margin:0 0 6px;color:var(--gc-text);}
  .badge.std{background:#eef0f2;color:var(--gc-text);border-radius:4px;font-size:15px;padding:6px 14px;}

  /* step navigation buttons */
  .step-nav{display:flex;flex-direction:column;gap:12px;margin-top:22px;}
  .btn-prev{
    width:100%;height:52px;background:#fff;border:1px solid var(--gc-navy);color:var(--gc-navy);
    border-radius:4px;font-weight:700;font-size:16px;cursor:pointer;font-family:var(--body);
  }
  .btn-next{
    width:100%;height:52px;background:var(--gc-navy);border:0;color:#fff;
    border-radius:4px;font-weight:700;font-size:16px;cursor:pointer;font-family:var(--body);
  }

  /* ---------- Grand total ---------- */
  .grand-total{
    display:flex;align-items:center;justify-content:space-between;gap:12px;
    border-top:1px solid var(--gc-rule);margin-top:8px;padding:18px 0 8px;flex-wrap:wrap;
  }
  .grand-total .lbl{font-family:var(--display);font-size:20px;font-weight:700;}
  .grand-total .badge{border-radius:4px;font-size:16px;padding:7px 16px;}

  /* ---------- Accessibility: visible focus ---------- */
  a:focus-visible,button:focus-visible{
    outline:3px solid var(--gc-focus);outline-offset:1px;
  }

  @media (prefers-reduced-motion:reduce){*{transition:none!important;}}

  /* ---------- Sticky bottom action bar ---------- */
  .bottombar{
    position:absolute;left:0;right:0;bottom:0;z-index:50;display:flex;align-items:stretch;
    background:#f1f2f4;border-top:1px solid var(--gc-border);box-shadow:0 -2px 8px rgba(0,0,0,.08);
  }
  .bb-item{
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;
    background:none;border:0;cursor:pointer;padding:10px 6px;min-height:62px;
    font-family:var(--body);font-size:13px;font-weight:700;color:var(--gc-navy);
  }
  .bb-item.grow{flex:1;}
  .bb-item.icononly{flex:0 0 auto;width:58px;}
  .bb-item svg{width:22px;height:22px;}
  .bb-sep{width:1px;background:var(--gc-border);margin:12px 0;flex:0 0 auto;}

  /* overflow ("more options") menu */
  .more-menu{
    position:absolute;right:8px;bottom:74px;z-index:70;background:#fff;
    border:1px solid var(--gc-border);border-radius:8px;box-shadow:0 8px 26px rgba(0,0,0,.20);
    min-width:188px;overflow:hidden;
  }
  .more-menu[hidden]{display:none;}
  .more-menu button{
    display:flex;align-items:center;gap:12px;width:100%;background:none;border:0;
    border-bottom:1px solid #eee;padding:14px 16px;font-size:15px;font-weight:700;
    color:var(--gc-navy);cursor:pointer;text-align:left;min-height:50px;font-family:var(--body);
  }
  .more-menu button:last-child{border-bottom:0;}
  .more-menu button.danger{color:var(--gc-danger);}
  .more-menu button svg{width:18px;height:18px;flex:0 0 auto;}

  /* ---------- Guidance modal (centered dialog) ---------- */
  .modal-overlay{
    position:absolute;inset:0;z-index:120;display:flex;align-items:center;justify-content:center;
    background:rgba(0,0,0,.45);padding:18px;
  }
  .modal-overlay[hidden]{display:none;}
  .modal{
    width:100%;max-width:300px;background:#fff;border-radius:8px;padding:24px 22px 22px;
    box-shadow:0 14px 44px rgba(0,0,0,.32);animation:sheetUp .2s ease;
  }
  .modal h2{font-family:var(--display);font-size:24px;font-weight:700;margin:0 0 16px;color:#1c1c1c;}
  .modal p{margin:0 0 18px;font-size:16px;}
  .modal ul{list-style:none;margin:0 0 24px;padding:0;}
  .modal li{display:flex;gap:9px;margin-bottom:16px;font-size:16px;}
  .modal li::before{content:"•";color:var(--gc-text);}
  .modal a{color:var(--gc-link);text-decoration:underline;text-underline-offset:2px;}
  .btn-modal-close{
    background:var(--gc-navy);color:#fff;border:0;border-radius:4px;height:44px;padding:0 24px;
    font-weight:700;font-size:15px;cursor:pointer;font-family:var(--body);
  }

  /* ---------- Toast ---------- */
  .toast{
    position:absolute;left:50%;bottom:86px;transform:translateX(-50%);z-index:130;
    background:var(--gc-navy);color:#fff;font-size:14px;font-weight:700;
    padding:10px 18px;border-radius:20px;box-shadow:0 6px 18px rgba(0,0,0,.25);
    opacity:0;pointer-events:none;transition:opacity .2s;
  }
  .toast.show{opacity:1;}

  /* ---------- Responsive: fill the real viewport on phone-sized screens ----------
     Wide screens keep the 320x680 phone frame as a preview ("presentation chrome").
     At/under 600px (a real phone, or a narrowed browser window) the frame unwraps:
     .device expands to the full viewport and the chrome is stripped. Because every
     overlay (form-nav sheet, cost-category sheet, Guidance modal, overflow menu,
     bottom bar, toast) is already anchored to .device, they all re-anchor to the
     viewport automatically. Move the 600px breakpoint to taste. */
  @media (max-width:600px){
    body{padding:0;background:#fff;}
    .device{
      width:100%;
      max-width:none;
      height:100vh;   /* fallback for browsers without dvh */
      height:100dvh;  /* tracks mobile browser chrome show/hide */
      border:0;
      border-radius:0;
      box-shadow:none;
    }
    .device-notch{display:none;}
  }
</style>
</head>
<body>

<div class="device" role="img" aria-label="Mobile preview of the DFO Funding application form">
  <div class="device-notch" aria-hidden="true"></div>

  <div class="app">

    <header>
      <div class="wordmark-row">
        <div class="wordmark">
          <svg class="flag" viewBox="0 0 1000 500" aria-hidden="true">
            <rect width="1000" height="500" fill="#fff"/>
            <rect width="250" height="500" fill="var(--gc-flag-red)"/>
            <rect x="750" width="250" height="500" fill="var(--gc-flag-red)"/>
            <path fill="var(--gc-flag-red)" d="M500,196.4 l13.6,25.4 c1.6,2.9 4.5,2.6 7.4,1 l9.8,-5.1 -7.3,38.6 c-1.5,7.1 1.1,9.1 5.7,4 l21.8,-24.4 5.6,13.1 c1.2,2.7 3.4,2.3 5.4,1.9 l20.7,-4.4 -6.7,24.4 c-1.4,5.4 -1,7.2 2.1,9.4 l7,5.6 -44.6,36.2 c-3,2.5 -2.1,3.5 -1.1,8.2 l3.7,12.3 -36.2,-3.1 c-4.5,-0.5 -5.4,1.2 -5.4,4 l1.7,41.2 -10.9,0 1.7,-41.2 c0,-2.8 -0.9,-4.5 -5.4,-4 l-36.2,3.1 3.7,-12.3 c1,-4.7 1.9,-5.7 -1.1,-8.2 l-44.6,-36.2 7,-5.6 c3.1,-2.2 3.5,-4 2.1,-9.4 l-6.7,-24.4 20.7,4.4 c2,0.4 4.2,0.8 5.4,-1.9 l5.6,-13.1 21.8,24.4 c4.6,5.1 7.2,3.1 5.7,-4 l-7.3,-38.6 9.8,5.1 c2.9,1.6 5.8,1.9 7.4,-1 z"/>
          </svg>
          <div class="gov">Government of Canada<span>Gouvernement du Canada</span></div>
        </div>
        <a class="lang" href="#" lang="fr" aria-label="Français">FR</a>
      </div>

      <div class="search">
        <input type="text" aria-label="Search Canada.ca" placeholder="Search Canada.ca">
