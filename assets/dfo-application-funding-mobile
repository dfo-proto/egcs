<script>
  // pencil icon markup reused in the "In progress" pills
  const PEN = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>`;
  // inject pencil markup into the placeholders rendered above
  document.querySelectorAll('.pill').forEach(p=>{ p.innerHTML = p.innerHTML.replace('${PEN}', PEN); });
</script>

<script>
  const CATS = ["Monitoring and reporting","Equipment and supplies","Salaries and wages","Travel","Professional services"];
  const state = { water:[], community:[] };

  function money(n){ return "CAD $" + Number(n||0).toLocaleString("en-CA"); }

  function toggleNav(btn){
    const nav = document.getElementById('mainnav');
    const open = nav.classList.toggle('open');
    btn.setAttribute('aria-expanded', open);
  }

  // ---- Bottom sheet ----
  function openSheet(){
    const s = document.getElementById('formsheet');
    s.hidden = false;
    const close = s.querySelector('.btn-close');
    if (close) close.focus();
    document.addEventListener('keydown', escClose);
  }
  function closeSheet(){
    document.getElementById('formsheet').hidden = true;
    document.removeEventListener('keydown', escClose);
    const trigger = document.querySelector('.menu-trigger');
    if (trigger) trigger.focus();
  }
  function escClose(e){ if (e.key === 'Escape') closeSheet(); }

  function toggleStep(btn){
    const step = btn.parentElement;
    const expanded = step.classList.toggle('expanded');
    btn.setAttribute('aria-expanded', expanded);
  }

  // ---- Guidance modal ----
  function openGuidance(){
    closeMore();
    const m = document.getElementById('guidance');
    m.hidden = false;
    m.querySelector('.btn-modal-close').focus();
    document.addEventListener('keydown', escGuidance);
  }
  function closeGuidance(){
    document.getElementById('guidance').hidden = true;
    document.removeEventListener('keydown', escGuidance);
  }
  function escGuidance(e){ if (e.key === 'Escape') closeGuidance(); }

  // ---- Overflow "more options" menu ----
  function toggleMore(e){
    e.stopPropagation();
    const m = document.getElementById('moremenu');
    if (m.hidden){ m.hidden = false; setTimeout(()=>document.addEventListener('click', outsideMore),0); }
    else closeMore();
  }
  function closeMore(){
    document.getElementById('moremenu').hidden = true;
    document.removeEventListener('click', outsideMore);
  }
  function outsideMore(e){ if (!e.target.closest('#moremenu')) closeMore(); }

  // ---- Save draft ----
  function saveDraft(){ toast('Draft saved'); }

  // ---- Lightweight toast ----
  let toastTimer;
  function toast(msg){
    const t = document.getElementById('toast');
    t.textContent = msg; t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(()=>t.classList.remove('show'), 1800);
  }

  function toggleActivity(id){ document.getElementById(id).classList.toggle('collapsed'); }

  // ---- Build the editable fieldset for an item (used for both Add and Edit) ----
  function formHTML(act, item, idx){
    const opts = ['<option value="">Select…</option>']
      .concat(CATS.map(c=>`<option value="${c}"${c===item.cat?' selected':''}>${c}</option>`))
      .join('');
    return `
      <div class="cc-form" data-id="${item.id}">
        <h4>Cost category ${idx}</h4>
        <div class="field" data-field="cat">
          <div class="field-label">Cost category <span class="req">(required)</span></div>
          <p class="field-help">Select a cost category from the list of eligible options for this activity. (Each activity can include multiple cost categories)</p>
          <p class="field-error"><span class="warn"></span><span class="msg"></span></p>
          <select class="f-cat" aria-label="Cost category" oninput="clearFieldError(this)">${opts}</select>
        </div>
        <div class="field" data-field="total">
          <div class="field-label">Total cost amount <span class="req">(required)</span></div>
          <p class="field-help">Enter the total cost amount for this cost category within this activity.</p>
          <p class="field-error"><span class="warn"></span><span class="msg"></span></p>
          <input type="number" class="f-total" inputmode="numeric" aria-label="Total cost amount" value="${item.total}" oninput="clearFieldError(this)">
        </div>
        <div class="field" data-field="req">
          <div class="field-label">Amount Requested from DFO <span class="req">(required)</span></div>
          <p class="field-help">Enter the amount you are requesting from DFO for this cost category within this activity.</p>
          <p class="field-error"><span class="warn"></span><span class="msg"></span></p>
          <input type="number" class="f-req" inputmode="numeric" aria-label="Amount Requested from DFO" value="${item.req}" oninput="clearFieldError(this)">
        </div>
        <div class="field" data-field="desc">
          <div class="field-label">Description</div>
          <p class="field-help">Include relevant details such as quantities, unit prices, specific items, etc.</p>
          <textarea class="f-desc" aria-label="Description">${item.desc||''}</textarea>
        </div>
        <div class="form-actions">
          <button class="btn-done" onclick="commitItem('${act}',${item.id})">Done</button>
          <button class="btn-delete" onclick="deleteItem('${act}',${item.id})">Delete</button>
        </div>
      </div>`;
  }

  function cardHTML(act, item){
    return `
      <div class="cc-card">
        <div class="cc-card-head"><h4 class="cc-name">${item.cat}</h4></div>
        <div class="cc-card-body">
          <div class="cc-row"><p class="k">Amount requested</p><p class="v">${money(item.req)}</p></div>
          <div class="cc-row"><p class="k">Total cost</p><p class="v">${money(item.total)}</p></div>
        </div>
        <div class="cc-card-actions">
          <button class="link-edit" onclick="editItem('${act}',${item.id})">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>Edit
          </button>
          <button class="link-delete" onclick="deleteItem('${act}',${item.id})">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>Delete
          </button>
        </div>`.concat('</div>');
  }

  // ---- Sheet-driven add/edit ----
  let currentEdit = null;  // {act, id, isNew}

  function openCostSheet(act, id, isNew){
    currentEdit = {act, id, isNew};
    const item = state[act].find(i=>i.id===id);
    const idx = state[act].indexOf(item) + 1;
    document.getElementById('cc-form-host').innerHTML = formHTML(act, item, idx);
    const s = document.getElementById('cc-sheet');
    s.hidden = false;
    const sel = s.querySelector('.f-cat'); if (sel) sel.focus();
    document.addEventListener('keydown', escCC);
  }

  function addCostCategory(act){
    if (currentEdit) return;                 // a sheet is already open
    const id = Date.now();
    state[act].push({id, cat:'', total:'', req:'', desc:'', isNew:true});
    openCostSheet(act, id, true);
  }

  function editItem(act, id){
    if (currentEdit) return;
    openCostSheet(act, id, false);
  }

  function closeCostSheet(){
    document.getElementById('cc-sheet').hidden = true;
    document.getElementById('cc-form-host').innerHTML = '';
    document.removeEventListener('keydown', escCC);
    currentEdit = null;
  }

  // Close button — discard. A never-saved (new) category is removed.
  function cancelCostSheet(){
    if (!currentEdit) return;
    const {act, id, isNew} = currentEdit;
    if (isNew) state[act] = state[act].filter(i=>i.id!==id);
    closeCostSheet();
    render(act);
  }
  function escCC(e){ if (e.key === 'Escape') cancelCostSheet(); }

  // ---- Done: validate, save, close sheet, show summary card ----
  function commitItem(act, id){
    if (!validateForm(id)) return;
    const form = document.querySelector(`#cc-form-host .cc-form[data-id="${id}"]`);
    const item = state[act].find(i=>i.id===id);
    if (!form || !item) return;
    item.cat   = form.querySelector('.f-cat').value;
    item.total = Number(form.querySelector('.f-total').value);
    item.req   = Number(form.querySelector('.f-req').value);
    item.desc  = form.querySelector('.f-desc').value;
    item.isNew = false;
    closeCostSheet();
    render(act);
  }

  function deleteItem(act, id){
    state[act] = state[act].filter(i=>i.id!==id);
    if (currentEdit && currentEdit.id === id) closeCostSheet();
    render(act);
  }

  // ---- Validation ----
  const WARN = `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2 1 21h22z"/><rect x="11" y="9" width="2" height="6" fill="#fff"/><rect x="11" y="16.3" width="2" height="2" fill="#fff"/></svg>`;

  function setError(field, msg){
    if (!field) return;
    field.classList.add('error');
    const warn = field.querySelector('.field-error .warn');
    if (warn && !warn.innerHTML.trim()) warn.innerHTML = WARN;
    const m = field.querySelector('.field-error .msg');
    if (m) m.textContent = msg;
  }
  function clearError(field){ if (field) field.classList.remove('error'); }
  function clearFieldError(el){ clearError(el.closest('.field')); }

  function validateForm(id){
    const form = document.querySelector(`#cc-form-host .cc-form[data-id="${id}"]`);
    if (!form) return true;
    form.querySelectorAll('.field').forEach(clearError);

    const cat = form.querySelector('.f-cat').value.trim();
    const totalRaw = form.querySelector('.f-total').value.trim();
    const reqRaw = form.querySelector('.f-req').value.trim();
    const total = Number(totalRaw), req = Number(reqRaw);
    let first = null;
    const err = (name, msg)=>{
      const f = form.querySelector(`.field[data-field="${name}"]`);
      setError(f, msg); if (!first) first = f;
    };

    if (!cat) err('cat', 'Select a cost category.');
    if (!totalRaw || isNaN(total) || total <= 0) err('total', 'Enter the total cost amount.');
    if (!reqRaw || isNaN(req) || req <= 0) err('req', 'Enter the amount requested from DFO.');
    else if (totalRaw && !isNaN(total) && total > 0 && req > total)
      err('req', 'Amount requested cannot exceed the total cost amount.');

    if (first){
      first.scrollIntoView({behavior:'smooth', block:'center'});
      const ctrl = first.querySelector('input,select,textarea');
      if (ctrl) ctrl.focus();
      return false;
    }
    return true;
  }

  function validateProjectName(){
    const input = document.getElementById('project-name');
    const field = input.closest('.field');
    if (!input.value.trim()){ setError(field, 'Enter a project name.'); return false; }
    clearError(field); return true;
  }

  function render(act){
    const wrap = document.getElementById(act+'-items');
    const items = state[act];
    let html = '';

    items.forEach(i=>{ if (!i.isNew) html += cardHTML(act, i); });

    const committed = items.filter(i=>!i.isNew);
    if (committed.length){
      const sumReq = committed.reduce((s,i)=>s+Number(i.req),0);
      const sumTot = committed.reduce((s,i)=>s+Number(i.total),0);
      html += `
        <div class="activity-totals">
          <hr class="at-divider">
          <div class="at-row"><p class="at-label">Total Amount requested</p><span class="badge std">${money(sumReq)}</span></div>
          <div class="at-row"><p class="at-label">Total cost</p><span class="badge std">${money(sumTot)}</span></div>
        </div>`;
      document.getElementById('badge-'+act).textContent = money(sumReq);
    } else {
      document.getElementById('badge-'+act).textContent = "CAD $0";
    }

    wrap.innerHTML = html;
    updateGrand();
  }

  function updateGrand(){
    const all = [...state.water, ...state.community]
      .filter(i=>!i.isNew).reduce((s,i)=>s+Number(i.req),0);
    document.getElementById('grand-badge').textContent = money(all);
  }
</script>
</body>
</html>
